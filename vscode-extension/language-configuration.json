{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^fn\\s+\\w+\\s*\\([^)]*\\)\\s*\\{\\s*$",
    "decreaseIndentPattern": "^\\}\\s*$"
  }
}
