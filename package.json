{
  "name": "cagents",
  "version": "0.1.0",
  "description": "Low-level programming for AI agents. A C-like DSL that compiles to agent files for Claude, Kiro, Gemini, Codex, and Cursor.",
  "type": "module",
  "bin": {
    "cagents": "./dist/cli-node.js"
  },
  "scripts": {
    "build": "bun build src/cli-node.ts --outfile dist/cli-node.js --target node --minify",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/cli-node.js"
  ],
  "keywords": [
    "claude",
    "kiro",
    "gemini",
    "codex",
    "cursor",
    "agent",
    "dsl",
    "compiler",
    "ai",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dc-dc-dc/cagents"
  },
  "homepage": "https://cagents.io",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "engines": {
    "node": ">=18"
  }
}
